<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hardware Store | Ultimate Security Solutions</title>
    <link rel="stylesheet" href="styles.css?v=FIX_V3_INLINE">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .store-container {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            gap: 2rem;
            padding: 4rem 40px;
        }

        /* Sidebar Filters */
        .filters-sidebar {
            width: 280px;
            flex-shrink: 0;
            position: sticky;
            top: 120px;
            height: fit-content;
            background: rgba(15, 28, 46, 0.8);
            border: 1px solid rgba(255, 215, 0, 0.1);
            padding: 2rem;
            backdrop-filter: blur(10px);
        }

        .filter-title {
            color: var(--color-accent);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
            border-bottom: 1px solid rgba(255, 215, 0, 0.2);
            padding-bottom: 0.5rem;
        }

        .filter-btn {
            display: block;
            width: 100%;
            text-align: left;
            background: none;
            border: none;
            color: var(--color-text);
            padding: 0.8rem 0;
            cursor: pointer;
            font-size: 0.95rem;
            transition: all 0.3s;
            opacity: 0.7;
        }

        .filter-btn:hover, .filter-btn.active {
            color: var(--color-accent);
            opacity: 1;
            padding-left: 10px;
        }

        /* Product Grid */
        .product-grid {
            flex-grow: 1;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 2rem;
        }

        .product-card {
            background: rgba(15, 28, 46, 0.6);
            border: 1px solid rgba(255, 215, 0, 0.1);
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }

        .product-card:hover {
            border-color: var(--color-accent);
            transform: translateY(-5px);
            background: rgba(15, 28, 46, 0.9);
        }

        .product-badge {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: var(--color-accent);
            color: var(--color-primary);
            font-size: 0.7rem;
            font-weight: 800;
            padding: 4px 8px;
            text-transform: uppercase;
            z-index: 10;
        }

        .product-img-container {
            height: 220px;
            background: #fff; /* White background for product photos */
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        .product-img {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
        }

        .product-info {
            padding: 1.5rem;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        .product-sku {
            font-family: monospace;
            font-size: 0.8rem;
            color: var(--color-muted);
            margin-bottom: 0.5rem;
        }

        .product-name {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--color-text);
            margin-bottom: 1rem;
            line-height: 1.3;
        }

        .product-price {
            font-size: 1.4rem;
            color: var(--color-accent);
            font-weight: 800;
            margin-bottom: 1rem;
        }

        .product-desc {
            font-size: 0.9rem;
            color: var(--color-muted);
            margin-bottom: 1.5rem;
            line-height: 1.4;
        }

        .add-to-cart-btn {
            margin-top: auto;
            width: 100%;
            padding: 1rem;
            background: transparent;
            border: 1px solid var(--color-accent);
            color: var(--color-accent);
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 1px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .add-to-cart-btn:hover {
            background: var(--color-accent);
            color: var(--color-primary);
        }

        /* Cart Overlay */
        .cart-overlay {
            position: fixed;
            top: 0;
            right: -400px;
            width: 400px;
            height: 100%;
            background: var(--color-secondary);
            border-left: 1px solid var(--color-accent);
            z-index: 2000;
            padding: 3rem 2rem;
            box-shadow: -10px 0 30px rgba(0,0,0,0.5);
            transition: right 0.4s cubic-bezier(0.1, 0.9, 0.2, 1);
            display: flex;
            flex-direction: column;
        }

        .cart-overlay.open {
            right: 0;
        }

        .cart-title {
            color: var(--color-accent);
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 2rem;
            text-align: center;
        }

        #cart-items {
            flex-grow: 1;
            overflow-y: auto;
            margin-bottom: 2rem;
        }

        .cart-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 0;
            border-bottom: 1px solid rgba(255, 215, 0, 0.1);
        }

        .cart-item-info h4 {
            font-size: 0.9rem;
            margin-bottom: 0.2rem;
        }

        .cart-item-info p {
            font-size: 0.8rem;
            color: var(--color-muted);
        }

        .remove-btn {
            background: none;
            border: none;
            color: #ff4d4d;
            cursor: pointer;
            font-size: 1.1rem;
        }

        .cart-form input, .cart-form textarea {
            width: 100%;
            background: rgba(0,0,0,0.3);
            border: 1px solid rgba(255, 215, 0, 0.2);
            color: white;
            padding: 0.8rem;
            margin-bottom: 1rem;
            border-radius: 4px;
        }

        .submit-quote-btn {
            width: 100%;
            padding: 1.2rem;
            background: var(--color-accent);
            color: var(--color-primary);
            border: none;
            font-weight: 800;
            text-transform: uppercase;
            cursor: pointer;
            letter-spacing: 2px;
        }

        .close-cart {
            margin-top: 1rem;
            color: var(--color-muted);
            background: none;
            border: none;
            cursor: pointer;
            text-transform: uppercase;
            font-size: 0.8rem;
            width: 100%;
        }

        /* Floating Cart Trigger */
        .floating-cart-trigger {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: var(--color-accent);
            color: var(--color-primary);
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            cursor: pointer;
            box-shadow: 0 5px 20px rgba(0,0,0,0.4);
            z-index: 1500;
            transition: transform 0.3s;
        }

        .floating-cart-trigger:hover {
            transform: scale(1.1);
        }

        .cart-count-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: #ff4d4d;
            color: white;
            font-size: 0.7rem;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
        }
    </style>
</head>
<body>
    
    <nav class="main-nav">
        <div class="nav-container">
            <div class="nav-links">
                <a href="index.html">Home</a>
                <a href="about.html">About</a>
                <a href="service_area.html">Service Area</a>
                <div class="dropdown">
                    <span class="dropdown-trigger active">Hardware <i class="fas fa-chevron-down" style="font-size: 0.7rem; margin-left: 5px;"></i></span>
                    <div class="dropdown-content">
                        <a href="ordering_system.html">All Products</a>
                        <a href="ordering_system.html?cat=platinum">Platinum Series</a>
                        <a href="ordering_system.html?cat=pro">Pro Series</a>
                        <a href="ordering_system.html?cat=nvr">NVR Systems</a>
                        <a href="ordering_system.html?cat=camera">IP Cameras</a>
                    </div>
                </div>
                <a href="accomplishments.html">Our Work</a>
                <a href="partners.html">Partners</a>
                <a href="reviews.html">Reviews</a>
                <a href="#contact" class="btn-contact">Contact Us</a>
            </div>
        </div>
    </nav>

    <header class="page-header hero" style="padding-bottom: 2rem;">
        <h1>Security Hardware Store</h1>
        <p>Direct-to-consumer and B2B security equipment. Add items to your quote request for a custom solution.</p>
    </header>

    <div class="store-container">
        <!-- Sidebar -->
        <aside class="filters-sidebar">
            <h3 class="filter-title">Categories</h3>
            <button class="filter-btn active" onclick="filterCategory('all')">All Products</button>
            <button class="filter-btn" onclick="filterCategory('platinum')">Platinum Series</button>
            <button class="filter-btn" onclick="filterCategory('pro')">Pro Series</button>
            <button class="filter-btn" onclick="filterCategory('nvr')">NVR Systems</button>
            <button class="filter-btn" onclick="filterCategory('camera')">Cameras</button>
        </aside>

        <!-- Main Grid -->
        <main id="product-grid" class="product-grid">
            <!-- Products injected by JS -->
        </main>
    </div>

    <!-- Floating Cart Trigger -->
    <div class="floating-cart-trigger" onclick="toggleCart(true)">
        <i class="fas fa-shopping-cart"></i>
        <div id="cart-count" class="cart-count-badge">0</div>
    </div>

    <!-- Cart Overlay -->
    <div id="cart-sidebar" class="cart-overlay">
        <h2 class="cart-title">Your Quote Request</h2>
        <div id="cart-items">
            <!-- Cart items injected by JS -->
        </div>
        
        <div class="cart-form">
            <form data-netlify="true" method="POST" name="quote-request">
                <input name="form-name" type="hidden" value="quote-request"/>
                <input id="form-items" name="items" type="hidden"/>
                <input name="name" placeholder="Contact Name" required="" type="text"/>
                <input name="email" placeholder="Email Address" required="" type="email"/>
                <textarea name="notes" placeholder="Additional details or specific requirements..." rows="4"></textarea>
                <button class="submit-quote-btn" type="submit">Submit Quote Request</button>
            </form>
            <button class="close-cart" onclick="toggleCart(false)">Continue Shopping</button>
        </div>
    </div>

    <footer>
        <p>&copy; 2025 Ultimate Security Solutions LLC. All Rights Reserved.</p>
    </footer>

    <script src="products.js"></script>
    <script>
        let cart = [];
        let currentCategory = 'all';

        function renderGrid() {
            const grid = document.getElementById('product-grid');
            grid.innerHTML = '';

            const filtered = products.filter(p => {
                if (currentCategory === 'all') return true;
                if (currentCategory === 'platinum') return p.category === 'platinum';
                if (currentCategory === 'pro') return p.category === 'pro';
                if (currentCategory === 'nvr') return p.sku.startsWith('LTN') || p.sku.startsWith('LXN');
                if (currentCategory === 'camera') return p.sku.startsWith('CMIP') || p.sku.startsWith('PTZ') || p.sku.startsWith('LXIP');
                return true;
            });

            filtered.forEach(p => {
                const card = document.createElement('div');
                card.className = 'product-card';
                const badge = p.category === 'pro' ? 'PRO SERIES' : 'PLATINUM';
                
                card.innerHTML = `
                    <div class="product-badge">${badge}</div>
                    <div class="product-img-container">
                        <img src="${p.image}" class="product-img" alt="${p.sku}" onerror="this.src='https://placehold.co/400x300?text=Security+Asset'">
                    </div>
                    <div class="product-info">
                        <div class="product-sku">${p.sku}</div>
                        <h3 class="product-name">${p.name}</h3>
                        <div class="product-price">$${p.price.toFixed(2)}</div>
                        <p class="product-desc">${p.description}</p>
                        <button class="add-to-cart-btn" onclick="addToCart('${p.sku}')">Add to Quote</button>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        function filterCategory(cat) {
            currentCategory = cat;
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('active');
                if(btn.innerText.toLowerCase().includes(cat)) btn.classList.add('active');
                if(cat === 'all' && btn.innerText.toLowerCase().includes('all')) btn.classList.add('active');
            });
            renderGrid();
        }

        function addToCart(sku) {
            const product = products.find(p => p.sku === sku);
            cart.push(product);
            updateCartUI();
            toggleCart(true);
        }

        function removeFromCart(index) {
            cart.splice(index, 1);
            updateCartUI();
        }

        function updateCartUI() {
            const itemsContainer = document.getElementById('cart-items');
            const countBadge = document.getElementById('cart-count');
            const hiddenInput = document.getElementById('form-items');

            countBadge.innerText = cart.length;
            itemsContainer.innerHTML = '';

            cart.forEach((item, index) => {
                const div = document.createElement('div');
                div.className = 'cart-item';
                div.innerHTML = `
                    <div class="cart-item-info">
                        <h4>${item.sku}</h4>
                        <p>$${item.price.toFixed(2)}</p>
                    </div>
                    <button class="remove-btn" onclick="removeFromCart(${index})">
                        <i class="fas fa-trash"></i>
                    </button>
                `;
                itemsContainer.appendChild(div);
            });

            hiddenInput.value = JSON.stringify(cart.map(i => ({sku: i.sku, price: i.price})));
        }

        function toggleCart(open) {
            const sidebar = document.getElementById('cart-sidebar');
            if (open) sidebar.classList.add('open');
            else sidebar.classList.remove('open');
        }

        // Init
        const urlParams = new URLSearchParams(window.location.search);
        const catParam = urlParams.get('cat');
        if (catParam) {
            currentCategory = catParam;
            // Update active filter button if visible
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('active');
                if(btn.innerText.toLowerCase().includes(catParam)) btn.classList.add('active');
            });
        }
        renderGrid();
    </script>
</body>
</html>